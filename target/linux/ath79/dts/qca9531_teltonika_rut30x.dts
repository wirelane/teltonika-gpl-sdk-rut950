/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "qca953x.dtsi"
#include "platform_name.dtsi"

/ {
	compatible = "teltonika,rut30x", "qca,qca9531";
	model = "TELTONIKA RUT300";

	aliases {
		serial0 = &uart;
	};

	leds {
		compatible = "gpio-leds";

		wan_led {
			label = "wan_led";
			gpios = <&gpio 0 GPIO_ACTIVE_HIGH>;
		};

		eth1_led {
			label = "eth1_led";
			gpios = <&gpio 4 GPIO_ACTIVE_HIGH>;
		};

		eth2_led {
			label = "eth2_led";
			gpios = <&gpio 3 GPIO_ACTIVE_HIGH>;
		};

		eth3_led {
			label = "eth3_led";
			gpios = <&gpio 2 GPIO_ACTIVE_HIGH>;
		};

		eth4_led {
			label = "eth4_led";
			gpios = <&gpio 1 GPIO_ACTIVE_HIGH>;
		};

		led_power {
			label = "power";
			gpios = <&gpio 15 GPIO_ACTIVE_LOW>;
			default-state = "on";
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 17 GPIO_ACTIVE_LOW>;
		};
	};

	tlt_gpios { // Modify according to wiki page "DTS syntax with Libgpiod changes"
		gpiochip_info {
			hw_0 {
				hwver = <0>;
				gpiochip_count = <1>;

				gpiochip_0 = <32>; // Built-in
			};
		};

		ioman {
			GPIO_11 {
				line_name = "GPIO_IN_1";
			};
			GPIO_12 {
				line_name = "GPIO_IN_2";
			};
			GPIO_13 {
				line_name = "GPIO_OUT_1";
			};
			GPIO_14 {
				line_name = "GPIO_OUT_2";
			};
		};

		ledman {
			GPIO_4 {
				line_name = "LED_ETH_GREEN_1";
			};
			GPIO_3 {
				line_name = "LED_ETH_GREEN_2";
			};
			GPIO_2 {
				line_name = "LED_ETH_GREEN_3";
			};
			GPIO_1 {
				line_name = "LED_ETH_GREEN_4";
			};
			GPIO_0 {
				line_name = "LED_ETH_GREEN_5";
			};
			GPIO_15 {
				line_name = "LED_POWER";
				active_low;
			};
		};
	};
};

&spi {
	status = "okay";
	num-cs = <1>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <25000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			boot: partition@0 {
				label = "u-boot";
				reg = <0x000000 0x020000>;
				read-only;
			};

			config: partition@20000 {
				label = "config";
				reg = <0x020000 0x010000>;
				read-only;
			};

			art: partition@30000 {
				label = "art";
				reg = <0x030000 0x010000>;
				read-only;
			};

			partition@40000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x040000 0xf30000>;
			};

			partition@f70000 {
				label = "event-log";
				reg = <0xf70000 0x090000>;
			};
		};
	};
};

&usb0 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	hub_port0: port@1 {
		reg = <1>;
		#trigger-source-cells = <0>;
	};
};

&usb_phy {
	status = "okay";
};

&uart {
	status = "okay";
};

&eth0 {
	status = "okay";
	phy-handle = <&swphy0>;
	mtd-mac-address = <&config 0x0>;
	mtd-mac-address-increment = <1>;
};

&eth1 {
	phy-handle = <&swphy4>;
	mtd-mac-address = <&config 0x0>;

	gmac-config {
		device = <&gmac>;
		switch-phy-swap = <1>;
	};
};
