/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include "ar9330.dtsi"
#include "platform_name.dtsi"

/ {
	compatible = "teltonika,rut2xx", "qca,ar9330";
	model = "Teltonika RUT2XX";

	aliases {
		serial0 = &uart;
	};

	gpio-export {
		compatible = "gpio-export";
		#size-cells = <0>;

		gpio_modem_reset {
			gpio-export,name = "modem_reset";
			gpio-export,output = <0>;
			gpios = <&gpio 18 GPIO_ACTIVE_HIGH>;
		};

		gpio_modem_power {
			gpio-export,name = "modem_power";
			gpio-export,output = <0>;
			gpios = <&gpio 19 GPIO_ACTIVE_HIGH>;
		};
	};

	leds {
		compatible = "gpio-leds";

		lan_led {
			label = "lan_led";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
		};

		wan_led {
			label = "wan_led";
			gpios = <&gpio 17 GPIO_ACTIVE_LOW>;
		};

		led_gen_2 {
			label = "mob_gen_2";
			gpios = <&gpio 8 GPIO_ACTIVE_HIGH>;
		};

		led_gen_3 {
			label = "mob_gen_3";
			gpios = <&gpio 24 GPIO_ACTIVE_HIGH>;
		};

		led_gen_4 {
			label = "mob_gen_4";
			gpios = <&gpio 21 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_1 {
			label = "mob_ssid_1";
			gpios = <&gpio 23 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "timer";
		};

		led_ssid_2 {
			label = "mob_ssid_2";
			gpios = <&gpio 7 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "timer";
		};

		led_ssid_3 {
			label = "mob_ssid_3";
			gpios = <&gpio 6 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "timer";
		};

		led_ssid_4 {
			label = "mob_ssid_4";
			gpios = <&gpio 26 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "timer";
		};

		led_ssid_5 {
			label = "mob_ssid_5";
			gpios = <&gpio 27 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "timer";
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 22 GPIO_ACTIVE_LOW>;
		};

		sim_holder {
			label = "sim_holder";
			linux,code = <BTN_0>;
			gpios = <&gpio 20 GPIO_ACTIVE_HIGH>;
		};
	};

	tlt_gpios { // Modify according to wiki page "DTS syntax with Libgpiod changes"
		gpiochip_info {
			hw_0 {
				hwver = <0>;
				gpiochip_count = <1>;

				gpiochip_0 = <32>; // Built-in
			};
		};

		ioman {
			GPIO_12 {
				line_name = "GPIO_OUT_1";
			};
			GPIO_16 {
				line_name = "GPIO_IN_1";
			};
		};

		ledman {
			GPIO_14 {
				line_name = "LED_ETH_GREEN_1";
				active_low;
			};
			GPIO_17 {
				line_name = "LED_ETH_GREEN_2";
				active_low;
			};
			GPIO_8 {
				line_name = "LED_TECH_GEN_2";
			};
			GPIO_24 {
				line_name = "LED_TECH_GEN_3";
			};
			GPIO_21 {
				line_name = "LED_TECH_GEN_4";
			};
			GPIO_23 {
				line_name = "LED_SSID_1";
			};
			GPIO_7 {
				line_name = "LED_SSID_2";
			};
			GPIO_6 {
				line_name = "LED_SSID_3";
			};
			GPIO_26 {
				line_name = "LED_SSID_4";
			};
			GPIO_27 {
				line_name = "LED_SSID_5";
			};
		};

		misc {
			GPIO_18 {
				line_name = "GPIO_MODEM_RESET_1";
			};
			GPIO_19 {
				line_name = "GPIO_MODEM_POWER_1";
			};
		};
	};
};

&mnfinfo {
	simpin1 {
		reg = <&config 0x68 0xc>;
		type = "digit";
		default = "";
		right-side-alligned;
	};

	sim_count {
		default =  "1";
	};

	blver {
		reg = <&boot 0x1fff6 0xa>;
		strip-whitespaces;
		type = "ascii";
		log;
	};
};

&spi {
	status = "okay";
	num-cs = <1>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <25000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			boot: partition@0 {
				label = "u-boot";
				reg = <0x000000 0x020000>;
				read-only;
			};

			config: partition@20000 {
				label = "config";
				reg = <0x020000 0x010000>;
				read-only;
			};

			art: partition@30000 {
				label = "art";
				reg = <0x030000 0x010000>;
				read-only;
			};

			partition@40000 {
				label = "firmware";
				reg = <0x040000 0xf30000>;
				compatible = "tplink,firmware";
			};

			partition@f70000 {
				label = "event-log";
				reg = <0xf70000 0x090000>;
			};
		};
	};
};

&uart {
	status = "okay";
};

&gpio {
	status = "okay";
};

&usb {
	dr_mode = "host";
	status = "okay";
};

&usb_phy {
	status = "okay";
};

&eth0 {
	status = "okay";
	mtd-mac-address = <&config 0x0>;
	mtd-mac-address-increment = <1>;
};

&eth1 {
	status = "okay";
	mtd-mac-address = <&config 0x0>;

	gmac-config {
		device = <&gmac>;
		switch-phy-addr-swap = <0>;
		switch-phy-swap = <0>;
	};
};

&wmac {
	status = "okay";
	mtd-mac-address = <&config 0x0>;
	mtd-mac-address-increment = <2>;
	mtd-cal-data = <&art 0x1000>;
};
